                                            ToolTip="读取 /proc/PID/cmdline 并以相同命令重新启动"/>
                                    <TextBlock Text="{Binding ProcessControlHint}" VerticalAlignment="Center" FontSize="11"
                                               Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,8,8"/>
                                </WrapPanel>
                            </StackPanel>
                        </Grid>
                    </TabItem>

