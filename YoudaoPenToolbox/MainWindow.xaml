                                      Background="{DynamicResource RegionBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      RowBackground="{DynamicResource RegionBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="PID" Binding="{Binding Pid, Mode=OneWay}" Width="56"/>
                                    <DataGridTextColumn Header="用户" Binding="{Binding User, Mode=OneWay}" Width="64"/>
                                    <DataGridTextColumn Header="CPU%" Binding="{Binding CpuPercentDisplay, Mode=OneWay}" SortMemberPath="CpuPercent" Width="56"/>
                                    <DataGridTextColumn Header="内存%" Binding="{Binding MemoryPercentDisplay, Mode=OneWay}" SortMemberPath="MemoryPercent" Width="64"/>
                                    <DataGridTextColumn Header="虚拟内存" Binding="{Binding VirtualMemory, Mode=OneWay}" Width="72"/>
                                    <DataGridTextColumn Header="状态" Binding="{Binding Stat, Mode=OneWay}" Width="48"/>
                                    <DataGridTextColumn Header="命令" Binding="{Binding Command, Mode=OneWay}" Width="180"/>
                                    <DataGridTextColumn Header="位置/路径" Binding="{Binding PathDisplay, Mode=OneWay}" Width="*"/>
                                </DataGrid.Columns>
                            </DataGrid>

                            <StackPanel Grid.Row="3" Margin="0,6,0,0">
                                <Border Style="{StaticResource DetailPanel}" Margin="0,0,0,6">
                                    <ScrollViewer VerticalScrollBarVisibility="Auto">
                                        <TextBlock Text="{Binding SelectedProcessDetail}" TextWrapping="Wrap" FontSize="14"
                                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    </ScrollViewer>
                                </Border>
