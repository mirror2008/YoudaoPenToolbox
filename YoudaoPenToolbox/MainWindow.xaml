                                         IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto"
                                         FontFamily="Consolas" MinHeight="280" Margin="0,0,0,8"
                                         hc:InfoElement.Placeholder="执行命令后，这里会显示易读的解析结果和原始输出..."/>
                            </StackPanel>
                        </ScrollViewer>
                    </TabItem>

