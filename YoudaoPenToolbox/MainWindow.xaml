<Window x:Class="YoudaoPenToolbox.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:hc="https://handyorg.github.io/handycontrol"
        xmlns:conv="clr-namespace:YoudaoPenToolbox.Converters"
        Title="有道词典笔工具箱"
        ResizeMode="CanResize"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">
    <Window.Resources>
        <conv:BoolToVisibilityConverter x:Key="BoolToVis"/>
        <conv:BoolToYesNoConverter x:Key="BoolToYesNo"/>
        <Style x:Key="StatCard" TargetType="Border">
            <Setter Property="Background" Value="{DynamicResource SecondaryRegionBrush}"/>
            <Setter Property="BorderBrush" Value="{DynamicResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="14"/>
            <Setter Property="Padding" Value="18,16"/>
            <Setter Property="Margin" Value="0,0,12,0"/>
            <Setter Property="MinWidth" Value="158"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="20" ShadowDepth="0" Opacity="0.08" Color="#000000"/>
                </Setter.Value>
            </Setter>
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="0"/>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="BorderBrush" Value="{DynamicResource PrimaryBrush}"/>
                    <Trigger.EnterActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="-3" Duration="0:0:0.28">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.EnterActions>
                    <Trigger.ExitActions>
                        <BeginStoryboard>
                            <Storyboard>
                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                 To="0" Duration="0:0:0.22">
                                    <DoubleAnimation.EasingFunction>
                                        <CubicEase EasingMode="EaseOut"/>
                                    </DoubleAnimation.EasingFunction>
                                </DoubleAnimation>
                            </Storyboard>
                        </BeginStoryboard>
                    </Trigger.ExitActions>
                </Trigger>
            </Style.Triggers>
        </Style>
        <Style x:Key="StatTitle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource SecondaryTextBrush}"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Margin" Value="0,0,0,6"/>
        </Style>
        <Style x:Key="StatValue" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{DynamicResource PrimaryTextBrush}"/>
            <Setter Property="FontSize" Value="20"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
        </Style>
        <Style x:Key="StatProgressBar" TargetType="ProgressBar">
            <Setter Property="Margin" Value="0,10,0,0"/>
        </Style>
        <Style x:Key="ThemeSegmentButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="MinHeight" Value="32"/>
            <Setter Property="Padding" Value="14,6"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="SegmentBorder"
                                Background="{TemplateBinding Background}"
                                CornerRadius="8"
                                Padding="{TemplateBinding Padding}"
                                RenderTransformOrigin="0.5,0.5">
                            <Border.RenderTransform>
                                <ScaleTransform ScaleX="1" ScaleY="1"/>
                            </Border.RenderTransform>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SegmentBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1.03" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                            <DoubleAnimation Storyboard.TargetName="SegmentBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1.03" Duration="0:0:0.2">
                                                <DoubleAnimation.EasingFunction><CubicEase EasingMode="EaseOut"/></DoubleAnimation.EasingFunction>
                                            </DoubleAnimation>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="SegmentBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleX)"
                                                             To="1" Duration="0:0:0.18"/>
                                            <DoubleAnimation Storyboard.TargetName="SegmentBorder"
                                                             Storyboard.TargetProperty="(UIElement.RenderTransform).(ScaleTransform.ScaleY)"
                                                             To="1" Duration="0:0:0.18"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid x:Name="WindowRoot" Background="Transparent">
        <Border x:Name="WindowShell"
            Margin="8"
            CornerRadius="12"
            Background="{DynamicResource RegionBrush}"
            BorderBrush="{DynamicResource BorderBrush}"
            BorderThickness="1"
            ClipToBounds="True"
            SnapsToDevicePixels="True">
        <Border.Effect>
            <DropShadowEffect BlurRadius="28" ShadowDepth="0" Opacity="0.28" Color="#000000" RenderingBias="Performance"/>
        </Border.Effect>

    <Viewbox x:Name="RootViewbox" Stretch="UniformToFill" StretchDirection="Both">
        <Grid Width="1440" Height="940">
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <Border x:Name="TitleBar" Grid.Row="0"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1"
                    CornerRadius="12,12,0,0"
                    PreviewMouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <Border Width="18" Height="18" CornerRadius="5" Margin="0,0,8,0" VerticalAlignment="Center">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#0078D4" Offset="0"/>
                                    <GradientStop Color="#409EFF" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="Y" FontSize="11" FontWeight="Bold" Foreground="White"
                                       HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0"/>
                        </Border>
                        <TextBlock Text="有道词典笔工具箱" FontSize="13" FontWeight="SemiBold"
                                   Foreground="{DynamicResource PrimaryTextBrush}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding AppVersion, StringFormat=' v{0}'}" FontSize="11"
                                   Foreground="{DynamicResource SecondaryTextBrush}" VerticalAlignment="Center"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource TitleBarButton}" Click="MinimizeWindow_Click"
                                ToolTip="最小化">
                            <Path Data="M0,0 H10" Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                  StrokeThickness="1.2" Width="10" Height="10" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                        <Button Style="{StaticResource TitleBarCloseButton}" Click="CloseWindow_Click"
                                ToolTip="关闭">
                            <Path Data="M0,0 L10,10 M10,0 L0,10"
                                  Stroke="{Binding RelativeSource={RelativeSource AncestorType=Button}, Path=Foreground}"
                                  StrokeThickness="1.2" Width="10" Height="10" Stretch="None"
                                  HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

    <Grid x:Name="RootContent" Grid.Row="1" Margin="16,12,16,16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*" MinHeight="0"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Style="{StaticResource PanelCard}" Padding="16,12" Margin="0,0,0,12">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <WrapPanel Grid.Row="0" Grid.Column="0" VerticalAlignment="Center">
                    <Border Background="{DynamicResource PrimaryBrush}" CornerRadius="6" Padding="10,3" Margin="0,0,14,4" VerticalAlignment="Center">
                        <TextBlock Text="百宝盒" Foreground="White" FontSize="11" FontWeight="SemiBold"/>
                    </Border>
                    <TextBlock Text="多设备管理 · 应用 · 文件 · 调试" VerticalAlignment="Center" Margin="0,0,14,4"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                </WrapPanel>

                <WrapPanel Grid.Row="0" Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <TextBlock Text="主题" VerticalAlignment="Center" Margin="0,0,10,4"
                               Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                    <Border Background="{DynamicResource ThirdlyRegionBrush}" CornerRadius="10" Padding="4" Margin="0,0,0,4"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                        <StackPanel Orientation="Horizontal">
                            <Button x:Name="ThemeAutoButton" Content="跟随时间" Style="{StaticResource ThemeSegmentButton}"
                                    Click="ThemeAutoButton_Click"/>
                            <Button x:Name="ThemeLightButton" Content="浅色" Style="{StaticResource ThemeSegmentButton}"
                                    Click="ThemeLightButton_Click"/>
                            <Button x:Name="ThemeDarkButton" Content="深色" Style="{StaticResource ThemeSegmentButton}"
                                    Click="ThemeDarkButton_Click"/>
                        </StackPanel>
                    </Border>
                </WrapPanel>

                <DockPanel Grid.Row="1" Grid.Column="0" Grid.ColumnSpan="2" Margin="0,10,0,0" LastChildFill="True">
                    <Button DockPanel.Dock="Right" Content="刷新设备" Command="{Binding RefreshDevicesCommand}"
                            Style="{StaticResource ButtonPrimary}" Margin="8,0,0,0" MinWidth="88"/>
                    <Button DockPanel.Dock="Right" Content="浏览" Command="{Binding BrowseAdbPathCommand}" Margin="8,0,0,0" MinWidth="72"/>
                    <TextBox Text="{Binding AdbPath, UpdateSourceTrigger=PropertyChanged}" Margin="0,0,8,0" MinWidth="0"
                             ToolTip="{Binding AdbPath}"
                             hc:InfoElement.Placeholder="adb.exe 路径"/>
                </DockPanel>
            </Grid>
        </Border>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" MinWidth="200"/>
                <ColumnDefinition Width="*" MinWidth="0"/>
            </Grid.ColumnDefinitions>

            <Border Grid.Column="0" Style="{StaticResource PanelCard}" Padding="14" Margin="0,0,12,0">
                <DockPanel LastChildFill="True">
                    <TextBlock Text="设备列表" FontWeight="SemiBold" FontSize="14" DockPanel.Dock="Top" Margin="4,0,0,12"/>
                    <ListBox ItemsSource="{Binding Devices}"
                             SelectedItem="{Binding SelectedDevice}"
                             BorderThickness="0"
                             Background="Transparent"
                             ScrollViewer.VerticalScrollBarVisibility="Auto">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Margin="4">
                                    <TextBlock Text="{Binding DisplayName}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                                    <TextBlock Text="{Binding Serial}" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}"/>
                                    <TextBlock Text="{Binding State}" FontSize="11">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding State}" Value="device">
                                                        <Setter Property="Foreground" Value="#4CAF50"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding State}" Value="offline">
                                                        <Setter Property="Foreground" Value="#F44336"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </DockPanel>
            </Border>

            <Grid Grid.Column="1">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*" MinHeight="0"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0" Grid.RowSpan="2"
                        Visibility="{Binding HasSelectedDevice, Converter={StaticResource BoolToVis}, ConverterParameter=Inverse}"
                        Style="{StaticResource PanelCard}">
                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                        <TextBlock Text="请连接词典笔并刷新设备列表" FontSize="16" HorizontalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                        <TextBlock Text="支持多台设备同时连接，选择左侧设备进行切换" FontSize="12" Margin="0,8,0,0"
                                   HorizontalAlignment="Center" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </StackPanel>
                </Border>

                <StackPanel Grid.Row="0" Visibility="{Binding HasSelectedDevice, Converter={StaticResource BoolToVis}}" Margin="0,0,0,8">
                    <StackPanel Margin="0,0,0,8">
                        <TextBlock Text="{Binding SelectedDevice.DisplayName}" FontSize="18" FontWeight="SemiBold"/>
                        <TextBlock Text="{Binding SelectedDevice.DetailInfo}" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,4,0,0"/>
                        <TextBlock Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12" Margin="0,2,0,0">
                            <Run Text="主机名: "/><Run Text="{Binding SelectedDevice.Hostname, Mode=OneWay}"/>
                        </TextBlock>
                    </StackPanel>

                    <Border Margin="0,0,0,12" Padding="12,10" CornerRadius="8"
                            Background="{DynamicResource ThirdlyRegionBrush}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            Visibility="{Binding NeedsAdbUnlock, Converter={StaticResource BoolToVis}}">
                        <DockPanel LastChildFill="True">
                            <Button DockPanel.Dock="Right" Content="付费解锁" Command="{Binding OpenAdbUnlockCommand}"
                                    Style="{StaticResource ButtonPrimary}" Width="100" Height="32" Margin="12,0,0,0"/>
                            <TextBlock Text="请先解锁 ADB，可通过 PenNewInject 付费解锁。" TextWrapping="Wrap"
                                       VerticalAlignment="Center"/>
                        </DockPanel>
                    </Border>

                    <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled" Margin="0,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="电量" Style="{StaticResource StatTitle}"/>
                                    <TextBlock Text="{Binding CurrentStatus.BatteryDisplay}" Style="{StaticResource StatValue}"/>
                                    <ProgressBar Style="{StaticResource StatProgressBar}"
                                                 Value="{Binding CurrentStatus.BatteryLevel, Mode=OneWay}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="CPU 使用率" Style="{StaticResource StatTitle}"/>
                                    <TextBlock Text="{Binding CurrentStatus.CpuDisplay}" Style="{StaticResource StatValue}"/>
                                    <ProgressBar Style="{StaticResource StatProgressBar}"
                                                 Value="{Binding CurrentStatus.CpuUsagePercent, Mode=OneWay}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="运行内存" Style="{StaticResource StatTitle}"/>
                                    <TextBlock Text="{Binding CurrentStatus.MemoryDisplay}" Style="{StaticResource StatValue}" FontSize="14"/>
                                    <ProgressBar Style="{StaticResource StatProgressBar}"
                                                 Value="{Binding CurrentStatus.MemoryUsagePercent, Mode=OneWay}" Margin="0,8,0,0"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}">
                                <StackPanel>
                                    <TextBlock Text="系统负载" Style="{StaticResource StatTitle}"/>
                                    <TextBlock Text="{Binding CurrentStatus.LoadDisplay}" Style="{StaticResource StatValue}" FontSize="14"/>
                                </StackPanel>
                            </Border>
                            <Border Style="{StaticResource StatCard}" Margin="0">
                                <StackPanel>
                                    <TextBlock Text="存储 (/userdisk)" Style="{StaticResource StatTitle}"/>
                                    <TextBlock Text="{Binding CurrentStatus.DiskDisplay}" Style="{StaticResource StatValue}" FontSize="14"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </StackPanel>

                <Border Grid.Row="1" Style="{StaticResource PanelCard}" Padding="14,10,14,14">
                <TabControl x:Name="MainTabControl"
                            SelectionChanged="MainTabControl_SelectionChanged"
                            VerticalAlignment="Stretch">
                    
                    <TabItem Header="APP 列表">
                        <Grid Margin="0,4,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="*" MinHeight="224"/>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0" Text="{Binding AppsSummaryText}" Margin="0,0,0,6"
                                       Foreground="{DynamicResource SecondaryTextBrush}"/>

                            <WrapPanel Grid.Row="1" Margin="0,0,0,8">
                                <TextBox Width="220" Text="{Binding SearchAppText, UpdateSourceTrigger=PropertyChanged}"
                                         hc:InfoElement.Placeholder="搜索名称/ID/分类" Margin="0,0,8,8"/>
                                <Button Content="搜索" Click="SearchApps_Click" Margin="0,0,8,8"/>
                                <Button Content="刷新列表" Command="{Binding RefreshAppsCommand}" Margin="0,0,8,8"/>
                                <Button Content="刷新占用" Command="{Binding RefreshAppSizesCommand}" Margin="0,0,8,8"/>
                                <Button Content="备份 AMR" Command="{Binding BackupSelectedAppCommand}" Margin="0,0,8,8"
                                        Style="{StaticResource ButtonPrimary}"
                                        ToolTip="选中应用后，从设备安装目录反向打包为 .amr"/>
                                <CheckBox Content="显示系统应用" IsChecked="{Binding ShowSystemApps}" VerticalAlignment="Center" Margin="0,0,8,8"/>
                            </WrapPanel>

                            <DataGrid Grid.Row="2" x:Name="AppsDataGrid"
                                      MinHeight="224"
                                      ItemsSource="{Binding InstalledApps}"
                                      SelectedItem="{Binding SelectedApp}"
                                      AutoGenerateColumns="False" IsReadOnly="True"
                                      HeadersVisibility="Column" CanUserAddRows="False"
                                      CanUserSortColumns="True" GridLinesVisibility="Horizontal"
                                      SelectionUnit="FullRow" SelectionMode="Single"
                                      VirtualizingPanel.IsVirtualizing="False"
                                      AlternatingRowBackground="{DynamicResource ThirdlyRegionBrush}"
                                      Background="{DynamicResource RegionBrush}"
                                      BorderBrush="{DynamicResource BorderBrush}"
                                      RowBackground="{DynamicResource RegionBrush}">
                                <DataGrid.Columns>
                                    <DataGridTextColumn Header="名称" Binding="{Binding Name, Mode=OneWay}" Width="180" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="版本" Binding="{Binding Version, Mode=OneWay}" Width="88" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="占用大小" Binding="{Binding SizeDisplay, Mode=OneWay}" SortMemberPath="SizeKb" Width="100" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="类型" Binding="{Binding AppType, Mode=OneWay}" Width="80" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="AppId" Binding="{Binding AppId, Mode=OneWay}" Width="170" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTextColumn Header="分类" Binding="{Binding Category, Mode=OneWay}" Width="120" IsReadOnly="True">
                                        <DataGridTextColumn.ElementStyle>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource DataGridCellText}"/>
                                        </DataGridTextColumn.ElementStyle>
                                    </DataGridTextColumn>
                                    <DataGridTemplateColumn Header="卸载" Width="72" IsReadOnly="True" SortMemberPath="UninstallDisplay">
                                        <DataGridTemplateColumn.CellTemplate>
                                            <DataTemplate>
                                                <TextBlock Text="{Binding UninstallDisplay, Mode=OneWay}"
                                                           Style="{StaticResource DataGridCellText}"/>
                                            </DataTemplate>
                                        </DataGridTemplateColumn.CellTemplate>
                                    </DataGridTemplateColumn>
                                </DataGrid.Columns>
                            </DataGrid>

                            <Border Grid.Row="3" Style="{StaticResource DetailPanel}" MaxHeight="48" Margin="0,6,0,0">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <TextBlock Text="{Binding SelectedAppDetail}" TextWrapping="Wrap" FontSize="14"
                                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                                </ScrollViewer>
                            </Border>

                            <WrapPanel Grid.Row="4" Margin="0,6,0,0">
                                <TextBox Width="120" Text="{Binding StartPage, UpdateSourceTrigger=PropertyChanged}"
                                         hc:InfoElement.Placeholder="启动页面" Margin="0,0,8,8"/>
                                <Button Content="启动选中" Command="{Binding StartAppCommand}" Margin="0,0,8,8"/>
                                <Button Content="备份 AMR" Command="{Binding BackupSelectedAppCommand}" Margin="0,0,8,8"
                                        ToolTip="从设备安装目录反向打包为 .amr，可拖至「APP 安装」页安装"/>
                                <Button Content="卸载选中" Command="{Binding UninstallAppCommand}" Margin="0,0,8,8"
                                        ToolTip="普通应用可备份后卸载；受保护系统应用将自动备份 AMR 并提示找回方式"/>
                                <TextBlock Text="点击表头「占用大小」可排序" VerticalAlignment="Center"
                                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="11" Margin="0,0,8,8"/>
                            </WrapPanel>
                        </Grid>
                    </TabItem>

                    <TabItem Header="APP 安装">
                        <ScrollViewer Margin="0,12,0,0" VerticalScrollBarVisibility="Auto">
                            <StackPanel>
                                <TextBlock Text="APP 安装（AMR 小程序包）" FontSize="16" FontWeight="SemiBold" Margin="0,0,0,8"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12">
                                    <Run Text="将 .amr 小程序包拖放到下方区域，或点击选择文件。安装前会弹出确认对话框，不会自动安装。"/>
                                </TextBlock>

                                <Border x:Name="AmrInstallDropZone" Style="{StaticResource DropZonePanel}" Height="120" Margin="0,0,0,12"
                                        AllowDrop="True"
                                        Drop="AmrInstallDropZone_Drop" DragEnter="AmrInstallDropZone_DragEnter"
                                        DragOver="AmrInstallDropZone_DragOver" DragLeave="AmrInstallDropZone_DragLeave"
                                        GiveFeedback="AmrInstallDropZone_GiveFeedback">
                                    <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                                        <TextBlock Text="将 .amr 小程序包拖放到此处安装" FontSize="15" HorizontalAlignment="Center"
                                                   Foreground="{DynamicResource PrimaryTextBrush}"/>
                                        <Button Content="选择 AMR 文件" Command="{Binding BrowseInstallAmrCommand}"
                                                Margin="0,10,0,0" HorizontalAlignment="Center"
                                                Style="{StaticResource ButtonPrimary}"/>
                                    </StackPanel>
                                </Border>

                                <TextBlock Text="一键安装 Loli" FontSize="16" FontWeight="SemiBold" Margin="0,8,0,8"/>
                                <TextBlock TextWrapping="Wrap" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12" LineHeight="20">
                                    <Run Text="兼容性检测会执行 uname -m、device-tree/compatible、/usr/bin、/dev、gst-launch-1.0、miniapp_cli 等指令，并据此选择安装分支："/>
                                    <LineBreak/>
                                    <Run Text="· rk-gst/ — RK 系列，GStreamer（已确认 X7、X7Pro）"/>
                                    <LineBreak/>
                                    <Run Text="· cvi-ffmpeg/ — CVI 系列，FFmpeg"/>
                                </TextBlock>

