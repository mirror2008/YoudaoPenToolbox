<Window x:Class="YoudaoPenToolbox.Views.SplashWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="YoudaoPenToolBox"
        WindowStartupLocation="Manual"
        WindowStyle="None"
        ResizeMode="NoResize"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        ShowInTaskbar="True"
        Topmost="True"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        TextOptions.TextFormattingMode="Display"
        Background="{DynamicResource RegionBrush}">
    <Viewbox Stretch="Uniform" StretchDirection="DownOnly">
        <Grid Width="1440" Height="940">
    <Grid x:Name="RootGrid" ClipToBounds="True" Background="{DynamicResource RegionBrush}">
        <Grid x:Name="ContentLayer">
            <Ellipse x:Name="AmbientGlow" Width="680" Height="680" HorizontalAlignment="Center" VerticalAlignment="Center"
                     IsHitTestVisible="False" Opacity="0.14" RenderTransformOrigin="0.5,0.5">
                <Ellipse.Fill>
                    <RadialGradientBrush GradientOrigin="0.5,0.5" Center="0.5,0.5" RadiusX="0.5" RadiusY="0.5">
                        <GradientStop Color="#0078D4" Offset="0"/>
                        <GradientStop Color="#000078D4" Offset="1"/>
                    </RadialGradientBrush>
                </Ellipse.Fill>
            </Ellipse>

            <Border x:Name="HeroCard" VerticalAlignment="Center" HorizontalAlignment="Center"
                    Padding="56,48" CornerRadius="28" Opacity="0"
                    Background="{DynamicResource SecondaryRegionBrush}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                    MinWidth="420" RenderTransformOrigin="0.5,0.5">
                <Border.RenderTransform>
                    <TransformGroup>
                        <ScaleTransform ScaleX="0.94" ScaleY="0.94"/>
                        <TranslateTransform Y="32"/>
                    </TransformGroup>
                </Border.RenderTransform>
                <Border.Effect>
                    <DropShadowEffect BlurRadius="48" ShadowDepth="0" Opacity="0.16" Color="#000000"/>
                </Border.Effect>

                <StackPanel HorizontalAlignment="Center">
                    <Border x:Name="LogoBadge" Width="72" Height="72" CornerRadius="20" Margin="0,0,0,24"
                            HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#0078D4" Offset="0"/>
                                <GradientStop Color="#409EFF" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="Y" FontSize="36" FontWeight="Bold" Foreground="White"
                                   HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-2,0,0"/>
                    </Border>

                    <TextBlock Text="YoudaoPenToolBox"
                               FontSize="34" FontWeight="Bold" HorizontalAlignment="Center"
                               Foreground="{DynamicResource PrimaryTextBrush}"/>
                    <TextBlock x:Name="SubtitleText" Text="Powered By MIRROR"
                               FontSize="14" HorizontalAlignment="Center" Margin="0,8,0,0" Opacity="0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>

                    <Grid x:Name="LoadingSpinner" Width="36" Height="36" Margin="0,36,0,0"
                          Opacity="0" HorizontalAlignment="Center" RenderTransformOrigin="0.5,0.5">
                        <Ellipse Width="36" Height="36"
                                 Stroke="{DynamicResource BorderBrush}"
                                 StrokeThickness="3"
                                 Opacity="0.35"/>
                        <Ellipse x:Name="SpinnerArc" Width="36" Height="36"
                                 Stroke="{DynamicResource PrimaryBrush}"
                                 StrokeThickness="3"
                                 StrokeDashArray="11 72"
                                 StrokeDashCap="Round"
                                 StrokeStartLineCap="Round"
                                 StrokeEndLineCap="Round"
                                 RenderTransformOrigin="0.5,0.5">
                            <Ellipse.RenderTransform>
                                <RotateTransform Angle="0"/>
                            </Ellipse.RenderTransform>
                        </Ellipse>
                    </Grid>

                    <TextBlock x:Name="StatusText" Text="正在启动..."
                               FontSize="13" HorizontalAlignment="Center" Margin="0,16,0,0" Opacity="0"
                               Foreground="{DynamicResource SecondaryTextBrush}"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="FooterText" Text="有道词典笔工具箱"
                       VerticalAlignment="Bottom" HorizontalAlignment="Center" Margin="0,0,0,36"
                       FontSize="12" Opacity="0"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
        </Grid>

        <Canvas x:Name="ShatterCanvas" Visibility="Collapsed" ClipToBounds="True" IsHitTestVisible="False"/>
    </Grid>
        </Grid>
    </Viewbox>
</Window>
