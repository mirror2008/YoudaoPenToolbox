<Window x:Class="YoudaoPenToolbox.Views.TextInputDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="输入"
        Width="420"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource RegionBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="20" Padding="20" CornerRadius="8"
            Background="{DynamicResource SecondaryRegionBrush}">
        <StackPanel>
            <TextBlock x:Name="PromptText" TextWrapping="Wrap" Margin="0,0,0,12"/>
            <TextBox x:Name="InputTextBox" FontSize="14" Margin="0,0,0,16"
                     KeyDown="InputTextBox_KeyDown"/>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="96" Height="36" Margin="0,0,12,0" IsCancel="True"/>
                <Button Content="确定" Width="96" Height="36" Style="{StaticResource ButtonPrimary}"
                        IsDefault="True" Click="Ok_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
