<Window x:Class="YoudaoPenToolbox.Views.RemoteFileActionDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="文件操作"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        Background="{DynamicResource RegionBrush}">
    <Border x:Name="DialogRoot" Style="{StaticResource DialogCard}" Margin="24">
        <StackPanel>
            <TextBlock Text="选择操作" Style="{StaticResource DialogTitle}" Margin="0,0,0,18"/>

            <Border Padding="14,12" CornerRadius="10" Background="{DynamicResource RegionBrush}" Margin="0,0,0,18">
                <StackPanel>
                    <TextBlock x:Name="FileNameText" FontSize="15" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock x:Name="FilePathText" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                               TextWrapping="Wrap" Margin="0,6,0,0"/>
                    <TextBlock x:Name="FileSizeText" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"
                               Margin="0,4,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock Text="请选择对该文件执行的操作：" FontSize="13"
                       Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,0,0,12"/>

            <StackPanel>
                <Button Content="下载到电脑..." Height="42" Margin="0,0,0,8"
                        HorizontalContentAlignment="Left" Padding="16,0"
                        Click="Download_Click"
                        ToolTip="选择保存位置后下载到电脑"/>
                <Button Content="记事本打开（内置）" Height="42" Margin="0,0,0,8"
                        HorizontalContentAlignment="Left" Padding="16,0"
                        Click="OpenText_Click"/>
                <Button Content="二进制查看（十六进制 + ASCII）" Height="42" Margin="0,0,0,8"
                        HorizontalContentAlignment="Left" Padding="16,0"
                        Click="OpenBinary_Click"/>
            </StackPanel>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="取消" Width="100" Height="38" IsCancel="True"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
