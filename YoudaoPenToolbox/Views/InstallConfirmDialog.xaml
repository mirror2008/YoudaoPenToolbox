<Window x:Class="YoudaoPenToolbox.Views.InstallConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="确认安装"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Topmost="True"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        Background="{DynamicResource RegionBrush}">
    <Border x:Name="DialogRoot" Style="{StaticResource DialogCard}" Margin="24">
        <StackPanel>
            <TextBlock Text="安装小程序" Style="{StaticResource DialogTitle}" Margin="0,0,0,18"/>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="72"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Border Width="64" Height="64" CornerRadius="14"
                        Background="{DynamicResource ThirdlyRegionBrush}"
                        BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1">
                    <Grid>
                        <Image x:Name="IconImage" Stretch="Uniform" Margin="8"/>
                        <TextBlock x:Name="IconPlaceholder" Text="APP"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Foreground="{DynamicResource SecondaryTextBrush}"/>
                    </Grid>
                </Border>

                <StackPanel Grid.Column="1" Margin="16,0,0,0" VerticalAlignment="Center">
                    <TextBlock x:Name="AppNameText" FontSize="20" FontWeight="SemiBold" TextWrapping="Wrap"/>
                    <TextBlock Margin="0,6,0,0" Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="版本 "/><Run x:Name="VersionText"/>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="AppId "/><Run x:Name="AppIdText"/>
                    </TextBlock>
                    <TextBlock Margin="0,4,0,0" Foreground="{DynamicResource SecondaryTextBrush}">
                        <Run Text="包大小 "/><Run x:Name="SizeText"/>
                    </TextBlock>
                </StackPanel>
            </Grid>

            <Border Padding="14,12" CornerRadius="10" Background="{DynamicResource RegionBrush}" Margin="0,0,0,14">
                <StackPanel>
                    <TextBlock Text="安装到设备" FontSize="12" Foreground="{DynamicResource SecondaryTextBrush}"/>
                    <TextBlock x:Name="DeviceNameText" FontSize="14" FontWeight="SemiBold" Margin="0,4,0,0" TextWrapping="Wrap"/>
                    <TextBlock x:Name="FileNameText" FontSize="11" Foreground="{DynamicResource SecondaryTextBrush}" Margin="0,6,0,0"/>
                </StackPanel>
            </Border>

            <TextBlock x:Name="WarningText" TextWrapping="Wrap" FontSize="12"
                       Foreground="#E6A23C" Margin="0,0,0,18" Visibility="Collapsed"/>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="取消" Width="100" Height="38" Margin="0,0,10,0" IsCancel="True"/>
                <Button Content="安装" Width="100" Height="38" Style="{StaticResource PrimaryActionButton}"
                        IsDefault="True" Click="Install_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
