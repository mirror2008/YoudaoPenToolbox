<Window x:Class="YoudaoPenToolbox.Views.UpdateWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="正在更新"
        Width="480"
        SizeToContent="Height"
        WindowStartupLocation="CenterScreen"
        ResizeMode="NoResize"
        ShowInTaskbar="True"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        Background="{DynamicResource RegionBrush}">
    <Border x:Name="DialogRoot" Style="{StaticResource DialogCard}" Margin="24">
        <StackPanel>
            <TextBlock Text="发现新版本" Style="{StaticResource DialogTitle}" Margin="0,0,0,14"/>
            <TextBlock x:Name="VersionTextBlock" TextWrapping="Wrap" Margin="0,0,0,10"
                       Foreground="{DynamicResource PrimaryTextBrush}"/>
            <TextBlock x:Name="StatusTextBlock" Text="正在下载更新..." TextWrapping="Wrap" Margin="0,0,0,14"
                       Foreground="{DynamicResource SecondaryTextBrush}"/>
            <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
            <TextBlock x:Name="ProgressTextBlock" HorizontalAlignment="Right" Margin="0,0,0,14"
                       Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
            <StackPanel x:Name="ActionPanel" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                <Button x:Name="RetryButton" Content="重试" Width="100" Height="38" Margin="0,0,10,0" Click="RetryButton_Click"/>
                <Button x:Name="ExitButton" Content="退出" Width="100" Height="38" Click="ExitButton_Click"/>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
