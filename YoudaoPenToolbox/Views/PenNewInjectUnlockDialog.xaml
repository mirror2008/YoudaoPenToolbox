<Window x:Class="YoudaoPenToolbox.Views.PenNewInjectUnlockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ADB 解锁"
        Width="520"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        Background="{DynamicResource RegionBrush}">
    <Window.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/SkinDefault.xaml"/>
                <ResourceDictionary Source="pack://application:,,,/HandyControl;component/Themes/Theme.xaml"/>
            </ResourceDictionary.MergedDictionaries>
        </ResourceDictionary>
    </Window.Resources>

    <Border Margin="20" Padding="20" CornerRadius="8"
            Background="{DynamicResource SecondaryRegionBrush}">
        <StackPanel>
            <TextBlock Text="ADB 解锁" FontSize="18" FontWeight="SemiBold" Margin="0,0,0,12"/>

            <StackPanel x:Name="IntroPanel">
                <TextBlock Text="请先解锁 ADB，可通过 PenNewInject 付费解锁。" TextWrapping="Wrap" Margin="0,0,0,16"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Width="96" Height="36" Margin="0,0,8,0" IsCancel="True"/>
                    <Button Content="付费解锁" Width="120" Height="36" Style="{StaticResource ButtonPrimary}"
                            Click="PayUnlockButton_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="PaymentPanel" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,16">
                    <Run Text="请使用邮件联系 "/>
                    <Run Text="nullplex2000@proton.me" FontWeight="SemiBold"/>
                    <Run Text=" 获取解锁 KEY，并付费 25 元。"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="返回" Width="96" Height="36" Margin="0,0,8,0" Click="BackButton_Click"/>
                    <Button Content="我已获取 KEY" Width="120" Height="36" Style="{StaticResource ButtonPrimary}"
                            Click="KeyReadyButton_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                <TextBlock x:Name="StatusTextBlock" Text="正在准备..." TextWrapping="Wrap" Margin="0,0,0,12"/>
                <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                <TextBlock x:Name="ProgressTextBlock" HorizontalAlignment="Right" Margin="0,0,0,12"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                <StackPanel x:Name="RetryPanel" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button Content="重试" Width="96" Height="36" Margin="0,0,8,0" Click="RetryButton_Click"/>
                    <Button Content="关闭" Width="96" Height="36" IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
