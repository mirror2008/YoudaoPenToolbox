<Window x:Class="YoudaoPenToolbox.Views.PenNewInjectUnlockDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="ADB 解锁"
        Width="540"
        SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        FontFamily="Segoe UI, Microsoft YaHei UI"
        Background="{DynamicResource RegionBrush}">
    <Border x:Name="DialogRoot" Style="{StaticResource DialogCard}" Margin="24">
        <StackPanel>
            <TextBlock Text="ADB 解锁" Style="{StaticResource DialogTitle}" Margin="0,0,0,14"/>

            <StackPanel x:Name="IntroPanel">
                <TextBlock Text="请先解锁 ADB，可通过 PenNewInject 付费解锁。" TextWrapping="Wrap" Margin="0,0,0,18"/>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="取消" Width="100" Height="38" Margin="0,0,10,0" IsCancel="True"/>
                    <Button Content="付费解锁" Width="120" Height="38" Style="{StaticResource PrimaryActionButton}"
                            Click="PayUnlockButton_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="PaymentPanel" Visibility="Collapsed">
                <TextBlock TextWrapping="Wrap" Margin="0,0,0,18">
                    <Run Text="请前往 "/>
                    <Hyperlink NavigateUri="https://afdian.com/a/Mirror_CN" RequestNavigate="ExternalLink_RequestNavigate">爱发电 · Mirror_CN</Hyperlink>
                    <Run Text=" 自助获取解锁 KEY。"/>
                </TextBlock>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="返回" Width="100" Height="38" Margin="0,0,10,0" Click="BackButton_Click"/>
                    <Button Content="我已获取 KEY" Width="120" Height="38" Style="{StaticResource PrimaryActionButton}"
                            Click="KeyReadyButton_Click"/>
                </StackPanel>
            </StackPanel>

            <StackPanel x:Name="ProgressPanel" Visibility="Collapsed">
                <TextBlock x:Name="StatusTextBlock" Text="正在准备..." TextWrapping="Wrap" Margin="0,0,0,14"/>
                <ProgressBar x:Name="DownloadProgressBar" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8"/>
                <TextBlock x:Name="ProgressTextBlock" HorizontalAlignment="Right" Margin="0,0,0,14"
                           Foreground="{DynamicResource SecondaryTextBrush}" FontSize="12"/>
                <StackPanel x:Name="RetryPanel" Orientation="Horizontal" HorizontalAlignment="Right" Visibility="Collapsed">
                    <Button Content="重试" Width="100" Height="38" Margin="0,0,10,0" Click="RetryButton_Click"/>
                    <Button Content="关闭" Width="100" Height="38" IsCancel="True"/>
                </StackPanel>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
